# Core environment
NODE_ENV=development

# Telephony API server port (main app.ts)
BV_PORT=3000

# Logging level for all services
BV_LOG_LEVEL=info

# Required integrations
BV_SARVAM_API_KEY=your_sarvam_api_key
BV_EXOTEL_SID=your_exotel_sid
BV_EXOTEL_TOKEN=your_exotel_token
BV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bharatvoice

# Optional n8n integration
BV_N8N_WEBHOOK_URL=

# Demo mode:
# standalone -> local web demo server
# embedded   -> demo embedded on marketing site (strict CORS)
# disabled   -> do not start web demo server
BV_DEMO_MODE=standalone

# Dedicated demo websocket/http port (separate from BV_PORT)
BV_DEMO_WS_PORT=3001

# Session TTL in minutes for GDPR-style expiration
BV_DEMO_TTL_MINUTES=60

# Max concurrent websocket demo users
BV_DEMO_MAX_CONCURRENT=100

# Analytics provider:
# console | postgresql | ga4
BV_ANALYTICS_PROVIDER=console

# Optional backward-compatible analytics backend key
# development | postgres | ga4
BV_ANALYTICS_BACKEND=development

# Comma-separated allowed origins for demo CORS.
# Required when BV_DEMO_MODE=embedded.
BV_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Demo feature flags
BV_DEMO_ENABLE_ANALYTICS=true
# Comma-separated list: dental,auto,legal
BV_DEMO_ENABLED_VERTICALS=dental,auto,legal

# GA4 credentials (required only when BV_ANALYTICS_PROVIDER=ga4)
BV_GA4_MEASUREMENT_ID=
BV_GA4_API_SECRET=
